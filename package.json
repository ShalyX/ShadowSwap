{
  "name": "shadowswap",
  "version": "0.1.0",
  "private": true,
  "description": "ShadowSwap — private Uniswap routing via iExec Nox (WTF Hackathon Summer Edition)",
  "scripts": {
    "contracts:install": "npm install --prefix contracts",
    "contracts:compile": "npm run compile --prefix contracts",
    "contracts:test": "npm run test --prefix contracts",
    "contracts:deploy:local": "npm run deploy:local --prefix contracts",
    "contracts:deploy:sepolia": "npm run deploy:sepolia --prefix contracts",
    "web:install": "npm install --prefix frontend",
    "web:dev": "npm run dev --prefix frontend",
    "web:build": "npm run build --prefix frontend",
    "setup": "npm run contracts:install && npm run web:install"
  },
  "keywords": [
    "nox",
    "iexec",
    "confidential",
    "uniswap",
    "defi",
    "hackathon"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
